generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  MANAGER
  TECHNICAL
  EMPLOYEE
}

enum Category {
  IT_SUPPORT
  FACILITIES
  HR
  OTHER
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum Status {
  OPEN
  ASSIGNED
  IN_PROGRESS
  RESOLVED
  CLOSED
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  role      Role
  createdAt DateTime @default(now())

  createdTickets  Ticket[]  @relation("CreatedTickets")
  assignedTickets Ticket[]  @relation("AssignedTickets")
  comments        Comment[]
  activities      Activity[]
}

// seq gives us a stable, gap-free-ish incrementing number to render
// human-friendly ticket numbers like TKT-001 without a race-condition-prone
// "count rows and +1" approach.
model Ticket {
  id     String @id @default(cuid())
  seq    Int    @unique @default(autoincrement())

  title       String
  description String
  category    Category
  priority    Priority
  status      Status   @default(OPEN)

  createdById String
  createdBy   User     @relation("CreatedTickets", fields: [createdById], references: [id])

  assignedToId String?
  assignedTo   User?   @relation("AssignedTickets", fields: [assignedToId], references: [id])

  comments   Comment[]
  activities Activity[]

  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  resolvedAt DateTime?
  closedAt   DateTime?

  @@index([status])
  @@index([assignedToId])
  @@index([createdById])
  @@index([priority])
}

model Comment {
  id        String   @id @default(cuid())
  content   String
  ticketId  String
  ticket    Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  authorId  String
  author    User     @relation(fields: [authorId], references: [id])
  createdAt DateTime @default(now())

  @@index([ticketId])
}

// Activity is the audit trail that powers the "activity timeline" UI:
// creation, assignment, status transitions, and comments all write a row here.
model Activity {
  id          String   @id @default(cuid())
  ticketId    String
  ticket      Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  actorId     String
  actor       User     @relation(fields: [actorId], references: [id])
  type        String
  description String
  createdAt   DateTime @default(now())

  @@index([ticketId])
}
